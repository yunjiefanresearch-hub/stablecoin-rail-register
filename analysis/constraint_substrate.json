{
  "schema": "cbsr-analysis/constraint_substrate",
  "version": "0.9.2",
  "status": "preview",
  "note": "The constraint substrate gives each (jurisdiction x constraint C1-C8) a structured POLE from a controlled vocabulary, each citing the tier1_legal record(s) it is transcribed from. compose_via_substrate() derives a corridor's feasibility by composing two jurisdictions' poles through the six interaction-set rules (analysis/interaction_sets.json), instead of reading a hand-curated inbound gate. A pole is present ONLY where a tier1_legal record backs it; cells with no record are absent and read as 'unset', and the deriver returns 'indeterminate' for any corridor whose load-bearing poles are unset rather than guessing. Pole ASSIGNMENT is currently authored (transcribed from the records); verifying each assignment against the primary text is part of the verification backlog — exactly the liability that bounds this layer's coverage.",
  "pole_vocabulary": {
    "C1": [
      "open",
      "licence_gated",
      "closed_set",
      "host_currency_first",
      "no_pathway",
      "prohibition"
    ],
    "C2": [
      "prescribed_hqla",
      "prescribed_flex",
      "informational"
    ],
    "C3": [
      "permitted",
      "prohibited_issuer",
      "prohibited_incl_agents",
      "silent"
    ],
    "C4": [
      "payment_instrument",
